Algoritmo Parcial_Ejercicio_5L // Solicitar un número del 1 al 10 hasta que el número sea inválido
	
    Definir num Como Entero
    
	Escribir " Bienvenido/Bienvenida "
    Escribir " Ingrese un número entre 1 y 10: "
    Leer num
    
    Mientras num >= 1 Y num <= 10 Hacer
        Escribir " Número válido. "
        Escribir " Ingrese otro número entre 1 y 10: "
        Leer num
    FinMientras
    
    Escribir " Número inválido. Fin del programa. "
    
FinAlgoritmo
